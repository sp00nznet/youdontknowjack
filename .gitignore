# --- Copyrighted game material (you must supply your own legally-dumped copy) ---
# The whole input/ tree is your own disc dump (EBOOT, PS3_GAME, data.toc, flash,
# talkshow, save, shaders, ...) and the gamedata/ VFS mounts — never committed.
input/
gamedata/
*.BIN
*.elf
*.SELF
*.self

# --- Build output ---
build/
out/
cmake-build-*/

# --- Generated recompiled code (656 MB; regenerate from your own ELF) ---
src/recomp/*.c
src/recomp/*.cpp
src/recomp/*.h
# NOTE: src/gen/ (HLE NID table) and src/compat/ (Win32 shims) ARE committed —
# they're small and make the harness build-ready without re-running the tools.

# --- Logs / scratch ---
*.log
run_*.txt
stderr*.txt
stdout*.txt
*.tmp

# --- IDE / OS ---
.vs/
.vscode/
*.user
*.suo
.idea/
Thumbs.db
.DS_Store
spu/

# --- Lifted SPU images (derived; regenerate via extract + spu_lifter + gen_spu_workloads) ---
src/spu_gen/

# --- Lifted Sony PRX / SPU-kernel code (derived from libsre.sprx / the SPURS SPU
#     kernel; regenerate from your own dump via ppu_lifter.py / spu_lifter.py).
#     The small NID export tables (libsre_exports.c) and *.json metadata stay. ---
prx/**/ppu_recomp*
prx/**/spu_recomp*
